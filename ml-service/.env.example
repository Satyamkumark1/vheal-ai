# Copy this to Railway's environment variables section

# Required for advanced clinical justification NLP scoring
# Without this, the service falls back to rule-based scoring (still works)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional — restricts CORS to specific origins in production
# Leave blank to allow all origins (fine for internal API-to-API calls)
ALLOWED_ORIGINS=https://your-backend.railway.app
